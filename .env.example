# OpenAI Debug Agent is optional. Jenkins does not need these values for the
# normal pytest/Docker build flow.

# Required only when running scripts/run_openai_debug_agent.py.
OPENAI_API_KEY=

# Responses API model. Change this if your OpenAI project uses a different model.
OPENAI_MODEL=gpt-5.4

# Keep false until you intentionally run the OpenAI-backed CLI.
OPENAI_DEBUG_AGENT_ENABLED=false

# Local API call timeout.
OPENAI_TIMEOUT_SECONDS=30

